# Required — get from https://aistudio.google.com
# Add multiple keys for automatic rotation when quota is hit
GEMINI_API_KEY1=your_first_gemini_key_here
GEMINI_API_KEY2=your_second_gemini_key_here
GEMINI_API_KEY3=your_third_gemini_key_here
GEMINI_API_KEY4=your_fourth_gemini_key_here

# Required — get from https://tavily.com (used for web search)
TAVILY_API_KEY=your_tavily_api_key_here

# Optional — password to protect the app
APP_PASSWORD=your_password_here

# Optional overrides
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=models/gemini-embedding-001
