# --- Access password (required) ---
# Pick anything. Share this with the reviewer to log in.
APP_PASSWORD=demo123

# --- Gemini API keys (required) ---
# Get one at https://aistudio.google.com/apikey
# You can add multiple keys for rate-limit rotation: GEMINI_API_KEY1, GEMINI_API_KEY2, ...
GEMINI_API_KEY=your_gemini_key_here

# --- Tavily API key (required for web search) ---
# Get one at https://tavily.com (free tier available)
TAVILY_API_KEY=your_tavily_key_here

# --- Optional model overrides ---
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_AUDIO_MODEL=gemini-2.5-flash
# GEMINI_EMBED_MODEL=models/gemini-embedding-001
