# Required — get a free key from https://aistudio.google.com
GEMINI_API_KEY1=your_gemini_key_here
# Optional: add GEMINI_API_KEY2, GEMINI_API_KEY3, … for automatic rotation
# when you hit the free-tier daily quota (20 chat calls per key).

# Required — get from https://tavily.com (used for web search)
TAVILY_API_KEY=your_tavily_api_key_here

# Optional — password to protect the app
APP_PASSWORD=your_password_here

# Optional overrides
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=models/gemini-embedding-001
